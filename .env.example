# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
JWT_SECRET=your_jwt_secret_here

# Encryption Key for tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
ENCRYPTION_KEY=your_encryption_key_here

# Meta/Facebook Webhook Configuration
META_WEBHOOK_VERIFY_TOKEN=your_meta_verify_token
META_APP_SECRET=your_meta_app_secret

# Threads Webhook Configuration  
THREADS_WEBHOOK_VERIFY_TOKEN=your_threads_verify_token
THREADS_APP_SECRET=your_threads_app_secret

# API Versions
GRAPH_VERSION=v25.0
THREADS_VERSION=v1.0

# Optional: AI Reply Generation
ANTHROPIC_API_KEY=your_anthropic_api_key

# Server Configuration
PORT=3000
NODE_ENV=development
