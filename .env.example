# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
JWT_SECRET=your_jwt_secret_here

# Encryption Key for tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
ENCRYPTION_KEY=your_encryption_key_here

# Session Secret
SESSION_SECRET=your_session_secret_here

# Base URL for OAuth callbacks (must match your deployed URL or localhost for dev)
APP_BASE_URL=http://localhost:3000

# ===========================================
# Facebook App Configuration
# Separate app required for Facebook Pages integration
# ===========================================
FB_APP_ID=your_facebook_app_id
FB_SECRET=your_facebook_app_secret
FB_WEBHOOK_VERIFY_TOKEN=your_facebook_webhook_verify_token

# ===========================================
# Instagram App Configuration  
# Can use same Meta app as Facebook OR separate app
# If using same app, set IG_APP_ID = FB_APP_ID
# ===========================================
IG_APP_ID=your_instagram_app_id
IG_SECRET=your_instagram_app_secret
IG_WEBHOOK_VERIFY_TOKEN=your_instagram_webhook_verify_token

# ===========================================
# Threads App Configuration
# Requires separate app registration for Threads API
# ===========================================
TH_APP_ID=your_threads_app_id
TH_SECRET=your_threads_app_secret
TH_WEBHOOK_VERIFY_TOKEN=your_threads_webhook_verify_token

# ===========================================
# Google Configuration (for Sheets & Drive)
# Single Google Cloud Project for both services
# ===========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_WEBHOOK_VERIFY_TOKEN=your_google_webhook_verify_token

# ===========================================
# API Versions
# ===========================================
GRAPH_VERSION=v21.0
THREADS_VERSION=v1.0

# ===========================================
# Optional: AI Reply Generation
# ===========================================
ANTHROPIC_API_KEY=your_anthropic_api_key

# ===========================================
# External API Access
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ===========================================
API_KEY=your_secure_api_key_here

# ===========================================
# Server Configuration
# ===========================================
PORT=3000
NODE_ENV=development
